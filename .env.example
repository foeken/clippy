# Clippy Configuration
# Copy this file to .env and customize for your environment.

EWS_CLIENT_ID=your-azure-app-client-id
EWS_REFRESH_TOKEN=your-refresh-token

# Cloud environment: "commercial" (default) or "gcc" for Office 365 US Government .us endpoints.
CLIPPY_CLOUD=commercial

# Optional: block write actions while preserving reads.
CLIPPY_READONLY=false
